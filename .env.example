# =========================================================
# AI Story Studio — Local Environment Template
# انسخ هذا الملف إلى .env وعدّل القيم محلياً فقط.
# لا تضع .env في Git.
# =========================================================

APP_ENV=development
APP_HOST=0.0.0.0
BACKEND_PORT=8810
FRONTEND_PORT=5173

# مثال Docker Desktop على Windows:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# مثال سيرفر Ollama داخل LAN:
# OLLAMA_BASE_URL=http://YOUR_OLLAMA_IP:11434

OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=180
VITE_API_BASE_URL=http://localhost:8810

# TTS Worker — Phase 1.2/1.3 (معطّل افتراضياً)
# فعّله فقط بعد تشغيل deploy/ai-server/tts-worker/ فعلياً على AI Server.
TTS_ENABLED=false
TTS_SERVICE_URL=http://AI_SERVER_LAN_IP:8851
TTS_TIMEOUT_SECONDS=60

# Image Worker — Phase 2.1 (معطّل افتراضياً)
# فعّله فقط بعد تشغيل deploy/ai-server/comfyui-lab/ فعلياً على AI Server.
IMAGE_SERVICE_ENABLED=false
IMAGE_SERVICE_URL=http://AI_SERVER_LAN_IP:8188
IMAGE_TIMEOUT_SECONDS=120

# Storage
DATA_DIR=./data
MAX_STORY_CHARS=25000

# تحسين القصص الطويلة: إذا تجاوز النص هذا العدد من الأحرف، يتم تقسيمه إلى
# أجزاء وتحسين كل جزء بطلب منفصل لـ Ollama بدل إرسال النص كاملاً دفعة واحدة.
# خُفِّض من 6000 إلى 3000 بعد رصد timeout حقيقي عند تشغيل Ollama بدون GPU
# (CPU-only fallback) بسبب ازدحام VRAM مع ComfyUI/AllTalk -- جزء أصغر + سقف
# توليد (num_predict) أصغر يكمل ضمن OLLAMA_TIMEOUT_SECONDS حتى على CPU.
LONG_STORY_CHUNK_CHARS=3000

# Security
SECRET_KEY=change-me-local-only
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
