# =========================================================
# AI Story Studio — Local Environment Template
# انسخ هذا الملف إلى .env وعدّل القيم محلياً فقط.
# لا تضع .env في Git.
# =========================================================

APP_ENV=development
APP_HOST=0.0.0.0
BACKEND_PORT=8810
FRONTEND_PORT=5173

# Ollama المحلي من داخل Docker Desktop على Windows
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_TIMEOUT_SECONDS=180

# TTS — مرحلة لاحقة
TTS_PROVIDER=mock
SILMA_TTS_BASE_URL=http://YOUR_SILMA_SERVER:8765

# Storage
DATA_DIR=./data
MAX_STORY_CHARS=25000

# Security
SECRET_KEY=change-me-local-only
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
