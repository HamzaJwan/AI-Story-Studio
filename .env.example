# =========================================================
# AI Story Studio — Local Environment Template
# انسخ هذا الملف إلى .env وعدّل القيم محلياً فقط.
# لا تضع .env في Git.
# =========================================================

APP_ENV=development
APP_HOST=0.0.0.0
BACKEND_PORT=8810
FRONTEND_PORT=5173

# مثال Docker Desktop على Windows:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# مثال سيرفر Ollama داخل LAN:
# OLLAMA_BASE_URL=http://YOUR_OLLAMA_IP:11434

OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=180
VITE_API_BASE_URL=http://localhost:8810

# TTS Worker — Phase 1.1 Audio Bridge (معطّل افتراضياً)
# لا تفعّله إلا بعد Benchmark Gate = PASS لخدمة TTS فعلية على AI Server.
TTS_ENABLED=false
TTS_SERVICE_URL=http://AI_SERVER_LAN_IP:TTS_SERVICE_PORT
TTS_TIMEOUT_SECONDS=30

# Storage
DATA_DIR=./data
MAX_STORY_CHARS=25000

# Security
SECRET_KEY=change-me-local-only
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
