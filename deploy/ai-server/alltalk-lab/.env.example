# External AllTalk-compatible service URL.
# Example only; replace locally in .env and do not commit real IPs.
TTS_SERVICE_URL=http://AI_SERVER_IP:7851

# Use only a licensed/owned/safe test voice available on the AllTalk service.
ALLTALK_TEST_VOICE=
ALLTALK_TEST_LANGUAGE=ar
ALLTALK_TEST_TEXT=مرحبا، هذا اختبار صوتي آمن لمشروع AI Story Studio.
ALLTALK_OUTPUT_NAME=ai_story_alltalk_test
